---
import BaseLayout from '../layouts/BaseLayout.astro';

const progression = [
  'Deterministic CLI',
  'Hybrid local + LLM',
  'Framework agents',
  'Multi-agent workflows',
  'Capstone coordinator'
];

const principles = [
  {
    title: 'Start with the use case',
    body: 'Understand the purpose before choosing the method, tool, or architecture.'
  },
  {
    title: 'Question the obvious answer',
    body: 'Best practice is only useful when it fits the problem in front of you.'
  },
  {
    title: 'Build through experiments',
    body: 'Prototype, test ideas, and let the work teach you what should come next.'
  },
  {
    title: 'Keep only what matters',
    body: 'Aim for the point where removing anything else would make the thing worse.'
  },
  {
    title: 'Clear traces, reports, and documentation',
    body: 'Make the work visible so others can follow and verify it.'
  }
];
---
<BaseLayout title="The Workbench">
  <div class="page home-page">
    <section class="site-shell hero" aria-labelledby="home-title">
      <span class="hero__rule" aria-hidden="true"></span>
      <h1 id="home-title">The Workbench</h1>
      <p class="hero__lead">A public workspace for things I’m building.</p>
      <div class="hero__copy">
        <p>The Workbench is where I keep work I want to share: live products like ReadyRoll, public GitHub projects like the Data Agent Suite, writing, and experiments. Some of it is commercial, some of it is for learning, and some of it is simply worth putting somewhere people can see it.</p>
      </div>
    </section>

    <section class="site-shell home-projects" aria-label="Featured projects">
      <div class="stack">
        <article class="feature-card">
          <p class="feature-card__label">Live Product</p>
          <h2 class="feature-card__title">ReadyRoll</h2>
          <p class="feature-card__summary">A no-account scheduling app that helps groups find the best date to meet.</p>
          <p class="feature-card__narrative">ReadyRoll started from a small coordination problem: groups want to meet, but finding a date often turns into a long thread of maybes and reminders.</p>
          <div class="metadata-grid" aria-label="ReadyRoll details">
            <div>
              <p class="meta-label">Status</p>
              <p class="meta-value">Live product</p>
            </div>
            <div>
              <p class="meta-label">Stack</p>
              <p class="meta-value">Next.js, TypeScript, Tailwind, Supabase, Vercel</p>
            </div>
            <div>
              <p class="meta-label">Features</p>
              <p class="meta-value">Discord bot integration</p>
            </div>
          </div>
          <p class="feature-card__link"><a class="text-link" href="/readyroll/">Read about ReadyRoll</a></p>
        </article>

        <article class="feature-card">
          <p class="feature-card__label">Agents Suite</p>
          <h2 class="feature-card__title">Agents Suite</h2>
          <p class="feature-card__summary">A growing suite of practical data agents built to understand agent architecture from the ground up.</p>
          <p class="feature-card__narrative">The suite starts with simple local Python agents that do recognisable data work: profiling datasets, reconciling records, and drafting data dictionaries. The aim is to learn where deterministic logic, review loops, and LLM support each belong.</p>
          <div class="metadata-grid" aria-label="Agents Suite details">
            <div>
              <p class="meta-label">Type</p>
              <p class="meta-value">Python CLI agents</p>
            </div>
            <div>
              <p class="meta-label">Approach</p>
              <p class="meta-value">Deterministic checks, traceable reports</p>
            </div>
            <div>
              <p class="meta-label">Output</p>
              <p class="meta-value">Optional LLM polish</p>
            </div>
          </div>
          <div class="progression">
            <p class="meta-label">Progression</p>
            <div class="progression__chips" aria-label="Agents Suite progression">
              {progression.map((item, index) => (
                <>
                  <span class="chip">{item}</span>
                  {index < progression.length - 1 && <span class="chip-arrow" aria-hidden="true">-&gt;</span>}
                </>
              ))}
            </div>
          </div>
          <p class="feature-card__link"><a class="text-link" href="/agents/">Explore the suite</a></p>
        </article>

        <aside class="callout" aria-labelledby="future-work-title">
          <div class="callout__inner">
            <p class="label">On the Bench</p>
            <h2 id="future-work-title">Future work</h2>
            <p>This site will grow slowly. New projects will be added when they are mature enough to explain clearly and useful enough to sit alongside the main work.</p>
          </div>
        </aside>
      </div>
    </section>

    <section class="site-shell principles-section" aria-labelledby="principles-title">
      <div class="principles-box">
        <div class="section-heading section-heading--wide section-heading--large">
          <h2 id="principles-title">Working Principles</h2>
        </div>
        <ul class="dot-list">
          {principles.map((principle) => (
            <li>
              <h3>{principle.title}</h3>
              <p>{principle.body}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>
  </div>
</BaseLayout>
