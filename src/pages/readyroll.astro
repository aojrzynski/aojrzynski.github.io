---
import BaseLayout from '../layouts/BaseLayout.astro';
import { externalLinks } from '../data/links';

const features = [
  {
    title: 'Create a planning board with a date range',
    body: 'Set up a shared board covering several weeks or months. Give it a name like "Game Night" or "RPG Session" and generate invite links.'
  },
  {
    title: 'Collect availability across weeks or months',
    body: 'Participants mark availability across the entire date range, not just one meeting at a time.'
  },
  {
    title: 'Let people vote Yes / Maybe / No',
    body: 'Participants can update their votes as plans change. Votes are saved against their participant token.'
  },
  {
    title: 'Show perfect days and best alternatives',
    body: 'ReadyRoll calculates which dates work for everyone, and highlights the best alternatives when perfect days are not available.'
  },
  {
    title: 'Mark planned days',
    body: 'The host marks dates as planned once the group has decided. The board can continue to be used for future planning.'
  },
  {
    title: 'Extend or reuse the board over time',
    body: 'Hosts can extend the date range or reuse the board rather than starting from scratch each time.'
  },
  {
    title: 'Discord bot integration',
    body: 'Connect the board to a Discord channel for group visibility and quick access.'
  }
];

const steps = [
  {
    title: 'Host creates a planning board',
    body: 'The host sets up a board with a rolling date range and receives an admin link for managing it.'
  },
  {
    title: 'Participants join by link',
    body: 'Each participant receives a unique link. No account, no password, no signup form.'
  },
  {
    title: 'Availability builds over time',
    body: 'Participants mark availability across the date range and can update votes as their schedule changes.'
  },
  {
    title: 'Best dates surface automatically',
    body: 'ReadyRoll shows which dates work for everyone, and highlights the best alternatives.'
  },
  {
    title: 'Host marks planned days and continues using the board',
    body: 'Once a date is chosen, the host marks it as planned. The board stays active for future planning.'
  }
];

const roadmap = [
  {
    title: 'Better group-chat support',
    body: 'Improve the Discord bot with clearer summaries, reminders, and board visibility. Explore support for other group-chat tools such as Slack.'
  },
  {
    title: 'Richer planning boards',
    body: 'Add features like notes, time preferences, location tracking, and better recurring date management.'
  },
  {
    title: 'Optional accounts',
    body: 'Add accounts for people who want saved groups, history, and preferences, while keeping the current accountless flow available.'
  },
  {
    title: 'Stronger organiser tools',
    body: 'Improve board management, participant controls, and organiser workflows.'
  }
];

const techNotes = [
  'Next.js',
  'TypeScript',
  'Tailwind CSS',
  'Supabase',
  'Vercel',
  'Discord Interactions API',
  'Link/token participation model',
  'Server-side Supabase access'
];
---
<BaseLayout title="ReadyRoll" description="A lightweight scheduling board for groups that meet regularly.">
  <div class="page readyroll-page">
    <section class="site-shell hero" aria-labelledby="readyroll-title">
      <span class="hero__rule" aria-hidden="true"></span>
      <h1 id="readyroll-title">ReadyRoll</h1>
      <p class="hero__lead">A lightweight scheduling board for groups that meet regularly.</p>
      <div class="hero__copy">
        <p>ReadyRoll helps recurring groups keep track of who can make which dates, without making everyone create an account. A host creates a shared date range, people mark availability, and the group can see the best upcoming dates without digging through chat.</p>
        <p>It is live, early, and deliberately small: enough structure to solve the planning problem without turning casual meetups into admin.</p>
      </div>
      <p class="hero__actions">
        <a class="text-link" href={externalLinks.readyroll} target="_blank" rel="noreferrer">Open ReadyRoll</a>
      </p>
    </section>

    <section class="section section--panel section--compact" aria-labelledby="product-status-title">
      <aside class="callout callout--status">
        <div class="callout__inner">
          <p class="label">Product Status</p>
          <h2 id="product-status-title" class="visually-hidden">Product Status</h2>
          <p>ReadyRoll is live and usable today. It is in early growth and built for small groups organising board games, RPGs, casual meetups, and similar plans.</p>
          <p>The product currently supports accountless planning and a Discord bot integration. It is being improved around real group usage and feedback.</p>
        </div>
      </aside>
    </section>

    <section class="site-shell section" aria-labelledby="why-exists-title">
      <div class="section-heading">
        <h2 id="why-exists-title">Why this exists</h2>
      </div>
      <div class="prose">
        <p>Recurring groups often need more than a one-off poll, but less than a full calendar system. Chat is good for conversation but bad at maintaining availability across weeks or months.</p>
        <p>People reply at different times, answers get buried, and the organiser ends up asking the same questions every few days. ReadyRoll gives the group a shared view of availability without replacing the places they already talk.</p>
      </div>
    </section>

    <section class="site-shell section" aria-labelledby="accountless-title">
      <div class="section-heading">
        <h2 id="accountless-title">Why accountless?</h2>
      </div>
      <div class="prose">
        <p>Most casual groups do not need another login just to find a date. ReadyRoll uses links and tokens instead of requiring accounts. This keeps planning lightweight and avoids collecting personal profiles for basic scheduling.</p>
        <p>The trade-off is that links need to be managed carefully and some persistent group features are easier with accounts. The long-term direction is to add optional accounts alongside the accountless flow, not replace it.</p>
      </div>
    </section>

    <section class="site-shell section" aria-labelledby="features-title">
      <div class="section-heading">
        <h2 id="features-title">What ReadyRoll does</h2>
      </div>
      <div class="card-grid">
        {features.map((feature) => (
          <article class="simple-card">
            <h3>{feature.title}</h3>
            <p>{feature.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section section--panel" aria-labelledby="how-it-works-title">
      <div class="section-heading">
        <h2 id="how-it-works-title">How it works</h2>
      </div>
      <div class="content-panel steps-panel">
        <ol class="steps-list">
          {steps.map((step, index) => (
            <li class="step">
              <span class="step__number" aria-hidden="true">{index + 1}</span>
              <div>
                <h3>{step.title}</h3>
                <p>{step.body}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <section class="site-shell section" aria-labelledby="group-chat-title">
      <div class="section-heading">
        <h2 id="group-chat-title">Built for group chat</h2>
      </div>
      <div class="prose">
        <p>ReadyRoll does not try to replace the places groups already talk. The Discord bot lets a group connect an event to a channel, check status, view planned days, and send people back to the voting page when needed.</p>
      </div>
    </section>

    <section class="section section--panel" aria-labelledby="roadmap-title">
      <div class="section-heading">
        <h2 id="roadmap-title">Where ReadyRoll is heading</h2>
      </div>
      <p class="section-note">Roadmap is subject to change based on usage and feedback.</p>
      <div class="content-panel">
        <ul class="roadmap-list">
          {roadmap.map((item) => (
            <li>
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section class="section section--panel" aria-labelledby="technical-notes-title">
      <div class="section-heading">
        <h2 id="technical-notes-title">Technical notes</h2>
      </div>
      <div class="content-panel">
        <ul class="tech-list">
          {techNotes.map((note) => <li>{note}</li>)}
        </ul>
      </div>
    </section>
  </div>
</BaseLayout>
