---
import BaseLayout from '../layouts/BaseLayout.astro';
import { externalLinks } from '../data/links';

const buildPrinciples = [
  {
    title: 'Small systems',
    body: 'I like projects that can be understood completely, not just demoed.'
  },
  {
    title: 'Useful before impressive',
    body: 'A tool should remove friction before it tries to look clever.'
  },
  {
    title: 'Traceable by default',
    body: 'Good systems make it possible to see what happened and why.'
  },
  {
    title: 'AI with boundaries',
    body: 'I am interested in AI where it supports a real workflow, not where it becomes the whole point.'
  }
];
---
<BaseLayout title="About" description="About Adam Ojrzynski and The Workbench.">
  <div class="page about-page">
    <section class="site-shell hero" aria-labelledby="about-title">
      <span class="hero__rule" aria-hidden="true"></span>
      <h1 id="about-title">About</h1>
      <div class="hero__copy">
        <p>I work in data and product, and I build small software projects outside work.</p>
        <p>Most of my work sits somewhere between messy data, unclear requirements, product decisions, and delivery. I tend to be most useful when the problem is not fully shaped yet and someone needs to turn it into something people can understand, build, and use.</p>
      </div>
    </section>

    <section class="site-shell section" aria-labelledby="got-here-title">
      <div class="section-heading">
        <h2 id="got-here-title">How I got here</h2>
      </div>
      <div class="prose">
        <p>I started closer to the hands-on side of things: websites, analytics, reporting, data pipelines, and the operational work around digital products. Over time, that moved into product management, data leadership, governance, migration, and larger data programmes.</p>
        <p>The common thread is fairly simple: take something messy, understand what matters, and build a clearer way forward.</p>
      </div>
    </section>

    <section class="site-shell section" aria-labelledby="workbench-exists-title">
      <div class="section-heading">
        <h2 id="workbench-exists-title">Why The Workbench exists</h2>
      </div>
      <div class="prose">
        <p>The Workbench is where I keep the projects that are useful enough to explain properly.</p>
        <p>Some are live products, like ReadyRoll. Some are learning projects, like the Agents Suite. I use them to explore ideas properly: not just what can be built, but what should be deterministic, what should be reviewed, where an LLM helps, and where it gets in the way.</p>
      </div>
    </section>

    <section class="site-shell section" aria-labelledby="build-title">
      <div class="section-heading">
        <h2 id="build-title">How I like to build</h2>
      </div>
      <ul class="dot-list">
        {buildPrinciples.map((principle) => (
          <li>
            <h3>{principle.title}</h3>
            <p>{principle.body}</p>
          </li>
        ))}
      </ul>
    </section>

    <section class="site-shell section" aria-labelledby="contact-title">
      <div class="section-heading">
        <h2 id="contact-title">Contact</h2>
      </div>
      <div class="contact-block">
        <div class="contact-links">
          <a class="text-link text-link--large" href={externalLinks.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
          <a class="text-link text-link--large" href={externalLinks.github} target="_blank" rel="noreferrer">GitHub</a>
        </div>
        <p class="muted">LinkedIn is the best place to contact me for now.</p>
      </div>
    </section>
  </div>
</BaseLayout>
