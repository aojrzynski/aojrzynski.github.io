---
import BaseLayout from '../layouts/BaseLayout.astro';
import { externalLinks } from '../data/links';

const explorationCards = [
  {
    title: 'What makes something an agent',
    body: 'Exploring the difference between a script, a prompt, a tool, and an agent that can reason, act, review, or coordinate work.'
  },
  {
    title: 'Start simple, then add layers',
    body: 'Begin with local tools and clear outputs, then add LLM support, review loops, frameworks, state, tool use, and coordination where they help.'
  },
  {
    title: 'Match the method to the job',
    body: 'Some tasks need rules and repeatability. Others benefit from probabilistic help. The use case should decide the architecture.'
  },
  {
    title: 'Traceable outputs and review loops',
    body: 'Every agent should leave enough evidence for someone to understand, check, and improve its work.'
  }
];

const currentStages = [
  {
    number: 1,
    title: 'Deterministic CLI',
    body: 'Local Python tools that run predictable checks and produce traceable outputs without LLMs.'
  },
  {
    number: 2,
    title: 'Local bounded agent',
    body: 'Agents with constrained tasks, defined inputs, and clear stopping points.'
  },
  {
    number: 3,
    title: 'Hybrid local + LLM support',
    body: 'Combine deterministic logic with optional LLM polish for summaries or suggestions.'
  }
];

const plannedStages = [
  {
    number: 4,
    title: 'Framework agents',
    body: 'Use agent frameworks for tool-calling, state management, and review loops.'
  },
  {
    number: 5,
    title: 'Multi-agent workflows',
    body: 'Multiple specialist agents working together on connected tasks.'
  },
  {
    number: 6,
    title: 'Capstone coordinator',
    body: 'A coordinator agent that routes work across specialist agents based on task type and context.'
  }
];

const completedAgents = [
  {
    label: 'Deterministic CLI / Local bounded agent',
    title: 'Data Quality Triage Agent',
    summary: 'Profiles datasets and flags likely data quality issues.',
    href: externalLinks.dqtAgent,
    details: [
      {
        label: 'Why it exists',
        value: 'Messy datasets often need a quick first pass before anyone knows where to look.'
      },
      {
        label: 'What it does',
        value: 'Runs deterministic checks for missing values, duplicate keys, date gaps, outliers, schema surprises, and unexpected categorical values.'
      },
      {
        label: 'Demonstrates',
        value: 'A local deterministic agent can be useful without handing core judgement to an LLM.'
      },
      {
        label: 'Outputs',
        value: 'Traceable reports, run summaries, optional LLM-polished explanation.'
      }
    ]
  },
  {
    label: 'Deterministic CLI / Config-driven validation',
    title: 'Data Reconciliation Agent',
    summary: 'Validates source-to-target data using mapping config and traceable comparison outputs.',
    href: externalLinks.reconciliationAgent,
    details: [
      {
        label: 'Why it exists',
        value: 'Migration and integration work often needs a clear answer to what matched, what is missing, and what changed.'
      },
      {
        label: 'What it does',
        value: 'Detects missing records, unexpected records, and value mismatches between source and target datasets.'
      },
      {
        label: 'Demonstrates',
        value: 'A practical agent can combine config, deterministic comparison logic, exception outputs, and optional summary polish.'
      },
      {
        label: 'Outputs',
        value: 'Traceable reports, exception CSVs, optional LLM summary.'
      }
    ]
  },
  {
    label: 'Hybrid local + LLM support',
    title: 'Data Dictionary Agent',
    summary: 'Creates first-pass data dictionaries from CSV and XLSX datasets.',
    href: externalLinks.dictionaryAgent,
    details: [
      {
        label: 'Why it exists',
        value: 'Data dictionaries are useful but often missing, stale, or too slow to create manually.'
      },
      {
        label: 'What it does',
        value: 'Profiles datasets, infers useful field information, applies config overrides, and creates first-pass dictionary outputs.'
      },
      {
        label: 'Demonstrates',
        value: 'A hybrid local-first agent can use deterministic profiling as the base and LLM suggestions only for safe description polish.'
      },
      {
        label: 'Outputs',
        value: 'Data dictionary draft, trace artifacts, report artifacts, optional LLM description suggestions.'
      }
    ]
  }
];

const plannedAgents = [
  {
    title: 'Governance and review',
    items: ['Data Contract Review Agent', 'Sensitive Data Review Agent']
  },
  {
    title: 'Testing and onboarding',
    items: ['Data Test Suggestion Agent', 'Dataset Onboarding Reviewer Agent']
  },
  {
    title: 'Investigation and delivery',
    items: ['Data Quality Investigation Workflow', 'Project Evidence Agent', 'Data Migration War Room']
  }
];
---
<BaseLayout title="Agents Suite" description="A staged set of data agents for learning agent architecture properly.">
  <div class="page agents-page">
    <section class="site-shell hero" aria-labelledby="agents-title">
      <span class="hero__rule" aria-hidden="true"></span>
      <h1 id="agents-title">Agents Suite</h1>
      <p class="hero__lead">A staged set of data agents for learning agent architecture properly.</p>
      <div class="hero__copy">
        <p>The Data Agent Suite is my way of learning agents by building them in layers. It starts with local tools that use deterministic checks and traceable outputs, then gradually adds LLM support, review loops, tool use, state, frameworks, and multi-agent coordination.</p>
        <p>The goal is to understand what makes something an agent, how these systems are built, and when an agent is more useful than simply asking an LLM.</p>
      </div>
    </section>

    <section class="site-shell section" aria-labelledby="exploring-title">
      <div class="section-heading">
        <h2 id="exploring-title">What this suite is exploring</h2>
      </div>
      <div class="card-grid">
        {explorationCards.map((card) => (
          <article class="simple-card simple-card--soft simple-card--marked">
            <h3>{card.title}</h3>
            <p>{card.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section section--panel" aria-labelledby="progression-title">
      <div class="section-heading">
        <h2 id="progression-title">Learning Progression</h2>
      </div>
      <p class="section-note">The suite follows a deliberate path from simple local tools to agents with state, tool-calling, and coordination.</p>
      <div class="content-panel content-panel--solid timeline-panel">
        <div class="timeline-group">
          <p class="timeline-label">Covered so far</p>
          <ol class="timeline-list">
            {currentStages.map((stage) => (
              <li class="timeline-item">
                <span class="timeline-number" aria-hidden="true">{stage.number}</span>
                <div>
                  <h3>{stage.title}</h3>
                  <p>{stage.body}</p>
                </div>
              </li>
            ))}
          </ol>
        </div>
        <div class="timeline-group">
          <p class="timeline-label">Planned next</p>
          <ol class="timeline-list" start="4">
            {plannedStages.map((stage) => (
              <li class="timeline-item">
                <span class="timeline-number" aria-hidden="true">{stage.number}</span>
                <div>
                  <h3>{stage.title}</h3>
                  <p>{stage.body}</p>
                </div>
              </li>
            ))}
          </ol>
        </div>
      </div>
    </section>

    <section class="section section--panel" aria-labelledby="completed-title">
      <div class="section-heading section-heading--large">
        <h2 id="completed-title">Completed Agents</h2>
      </div>
      <div class="stack">
        {completedAgents.map((agent) => (
          <article class="feature-card agent-card">
            <p class="feature-card__label">{agent.label}</p>
            <h3 class="feature-card__title">{agent.title}</h3>
            <p class="feature-card__summary">{agent.summary}</p>
            <div class="metadata-grid metadata-grid--details">
              {agent.details.map((detail) => (
                <div>
                  <p class="meta-label">{detail.label}</p>
                  <p class="meta-value">{detail.value}</p>
                </div>
              ))}
            </div>
            <p class="feature-card__link">
              <a class="text-link" href={agent.href} target="_blank" rel="noreferrer">View GitHub repo</a>
            </p>
          </article>
        ))}
      </div>
    </section>

    <section class="section section--panel" aria-labelledby="planned-title">
      <div class="section-heading section-heading--large">
        <h2 id="planned-title">Planned Agents</h2>
      </div>
      <div class="content-panel">
        <div class="planned-list">
          {plannedAgents.map((group) => (
            <section aria-label={group.title}>
              <h3>{group.title}</h3>
              <ul>
                {group.items.map((item) => <li>{item}</li>)}
              </ul>
            </section>
          ))}
        </div>
        <p class="panel-note">Planned agents are included to show the intended direction of the suite. This roadmap may change.</p>
      </div>
    </section>

    <section class="site-shell section" aria-labelledby="heading-title">
      <div class="closing-section">
        <div class="section-heading">
          <h2 id="heading-title">Where this is heading</h2>
        </div>
        <div class="prose">
          <p>The suite is moving from local deterministic tools toward agents with state, review loops, and tool-calling. The early agents are deliberately simple because the goal is to understand the building blocks before adding complexity.</p>
          <p>Eventually, the suite will include a coordinator agent that can route work across specialist agents based on task type and context. Before that happens, the individual agents need to be useful, traceable, and trustworthy on their own.</p>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
