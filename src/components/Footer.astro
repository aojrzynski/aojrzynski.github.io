---
import { externalLinks } from '../data/links';
---
<footer class="site-footer">
  <div class="site-shell site-footer__inner">
    <a class="footer-brand" href="/" aria-label="The Workbench home">
      <span class="footer-brand__mark" aria-hidden="true"></span>
      <span>The Workbench</span>
