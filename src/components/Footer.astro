      <a class="icon-link" href={externalLinks.linkedin} target="_blank" rel="noreferrer" aria-label="LinkedIn">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M6.94 8.84H3.88V19.5h3.06V8.84ZM5.41 4.5a1.77 1.77 0 1 0 0 3.54 1.77 1.77 0 0 0 0-3.54Zm14.71 8.72c0-3.04-1.62-4.45-3.78-4.45a3.25 3.25 0 0 0-2.96 1.63h-.04V8.84h-2.94V19.5h3.06v-5.27c0-1.39.26-2.74 1.99-2.74 1.7 0 1.72 1.59 1.72 2.83v5.18h3.06l-.01-6.28Z" />
        </svg>
      </a>
      <a class="footer-readyroll text-link text-link--muted" href={externalLinks.readyroll} target="_blank" rel="noreferrer">
        ReadyRoll
      </a>
    </nav>
  </div>
</footer>
