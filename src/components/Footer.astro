    <nav class="footer-links" aria-label="Footer links">
      <a class="icon-link" href={externalLinks.github} target="_blank" rel="noreferrer" aria-label="GitHub">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 2.25a9.75 9.75 0 0 0-3.08 19c.49.09.67-.21.67-.47v-1.71c-2.72.59-3.29-1.16-3.29-1.16-.45-1.14-1.1-1.44-1.1-1.44-.9-.62.07-.61.07-.61.99.07 1.51 1.02 1.51 1.02.88 1.5 2.3 1.07 2.86.82.09-.64.35-1.07.63-1.32-2.17-.25-4.45-1.09-4.45-4.83 0-1.07.38-1.94 1.01-2.62-.1-.25-.44-1.25.1-2.59 0 0 .83-.27 2.69 1 .78-.22 1.61-.33 2.44-.33.83 0 1.66.11 2.44.33 1.86-1.27 2.68-1 2.68-1 .55 1.34.21 2.34.11 2.59.63.68 1.01 1.55 1.01 2.62 0 3.75-2.29 4.58-4.47 4.82.36.31.68.92.68 1.85v2.56c0 .26.18.57.68.47A9.75 9.75 0 0 0 12 2.25Z" />
