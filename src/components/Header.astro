---
const { currentPath = '/' } = Astro.props;

const nav = [
  { href: '/', label: 'Home' },
  { href: '/readyroll/', label: 'ReadyRoll' },
  { href: '/agents/', label: 'Data Agent Suite' },
  { href: '/about/', label: 'About' }
];

const normalizePath = (path: string) => (path === '/' ? '/' : path.replace(/\/$/, '') + '/');
const activePath = normalizePath(currentPath);
---
<header class="site-header">
  <div class="site-shell site-header__inner">
    <a class="brand" href="/" aria-label="The Workbench home">
      <span class="brand__mark" aria-hidden="true"></span>
      <span>The Workbench</span>
    </a>
    <nav class="site-nav" aria-label="Primary navigation">
      {nav.map((item) => (
        <a href={item.href} aria-current={activePath === item.href ? 'page' : undefined}>
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>
