---
const { currentPath } = Astro.props;
const nav = [
  { href: '/', label: 'Home' },
  { href: '/readyroll/', label: 'ReadyRoll' },
  { href: '/agents/', label: 'Agents Suite' },
  { href: '/about/', label: 'About' }
];
---
<header class="container site-header">
  <a href="/" class="brand"><span class="brand-mark" aria-hidden="true"></span>The Workbench</a>
  <nav aria-label="Primary">
    <ul>
      {nav.map((item) => (
        <li>
          <a href={item.href} aria-current={currentPath === item.href ? 'page' : undefined}>{item.label}</a>
        </li>
      ))}
    </ul>
  </nav>
</header>
<style>
.site-header{position:relative;display:flex;justify-content:space-between;gap:1.2rem;padding:1.35rem 1.6rem 1.1rem;align-items:baseline}
.site-header::after{content:"";position:absolute;left:50%;transform:translateX(-50%);bottom:0;width:100vw;height:1px;background:var(--color-ink-12)}
.brand{display:inline-flex;align-items:baseline;gap:.72rem;text-decoration:none;font-weight:620;color:var(--color-ink);font-size:1.08rem;line-height:1}
.brand-mark{width:5px;height:20px;background:var(--color-accent);border-radius:1px;transform:translateY(2px)}
ul{display:flex;flex-wrap:wrap;list-style:none;gap:1.15rem;margin:0;padding:0;align-items:baseline}
li{display:flex;align-items:baseline}
a{text-decoration:none;color:var(--color-muted);font-size:.95rem;line-height:1.1}
a[aria-current='page']{color:var(--color-ink)}
a:hover,a:focus-visible{color:var(--color-ink)}
a:focus-visible{outline:1px solid var(--color-accent-40);outline-offset:3px;border-radius:2px}
</style>
